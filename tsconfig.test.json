{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "lib": ["ESNext", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Node",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2020",
    "types": ["node", "vitest/globals"]
  },
  "include": ["tests/**/*.ts", "*.config.ts"],
  "exclude": ["node_modules"]
}
