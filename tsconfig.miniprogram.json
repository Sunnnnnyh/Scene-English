{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "lib": ["ES2020"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "noImplicitThis": true,
    "strict": true,
    "target": "ES2020",
    "types": ["miniprogram-api-typings"]
  },
  "include": ["miniprogram/**/*.ts", "miniprogram/**/*.d.ts"],
  "exclude": ["node_modules", "miniprogram/miniprogram_npm"]
}
