{
  "name": "sceneenglish",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A scene-driven English word learning WeChat Mini Program.",
  "scripts": {
    "typecheck": "tsc -p tsconfig.miniprogram.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "lint": "eslint \"miniprogram/**/*.{ts,js}\" \"tests/**/*.ts\" \"*.config.ts\"",
    "format": "prettier --write --ignore-unknown \"miniprogram/**/*.{ts,js,json,wxml,wxss}\" \"tests/**/*.ts\" \"package.json\" \"tsconfig*.json\" \"vitest.config.ts\" \"eslint.config.js\" \".prettierrc.json\"",
    "format:check": "prettier --check --ignore-unknown \"miniprogram/**/*.{ts,js,json,wxml,wxss}\" \"tests/**/*.ts\" \"package.json\" \"tsconfig*.json\" \"vitest.config.ts\" \"eslint.config.js\" \".prettierrc.json\"",
    "test": "vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.0.0",
    "miniprogram-api-typings": "^4.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
