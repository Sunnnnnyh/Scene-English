.placeholder-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 64rpx 40rpx;
  background: #f7fbff;
}

.placeholder-title {
  display: block;
  color: #19324d;
  font-size: 40rpx;
  font-weight: 800;
}

.placeholder-copy {
  display: block;
  margin-top: 20rpx;
  color: #45647f;
  font-size: 28rpx;
}

.back-button {
  margin: 40rpx 0 0;
  min-height: 88rpx;
  border: 2rpx solid #19324d;
  border-radius: 999rpx;
  background: #f38d68;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
}
