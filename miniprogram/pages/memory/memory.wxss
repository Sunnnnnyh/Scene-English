.memory-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 48rpx 32rpx 64rpx;
  background: #f7fbff;
}

.memory-kicker {
  display: block;
  color: #5d7892;
  font-size: 24rpx;
  font-weight: 700;
}

.memory-title {
  display: block;
  margin-top: 8rpx;
  color: #19324d;
  font-size: 40rpx;
  font-weight: 800;
}

.memory-subtitle {
  display: block;
  margin-top: 22rpx;
  color: #45647f;
  font-size: 28rpx;
  line-height: 1.5;
}

.memory-scene-frame {
  width: 100%;
  aspect-ratio: 16 / 9;
  margin-top: 34rpx;
  overflow: hidden;
  border: 3rpx solid #19324d;
  border-radius: 24rpx;
  background: #eaf5ff;
  box-shadow: 0 16rpx 32rpx rgba(25, 50, 77, 0.08);
}

.memory-scene-image {
  display: block;
  width: 100%;
  height: 100%;
}

.back-button {
  margin: 40rpx 0 0;
  min-height: 88rpx;
  border: 2rpx solid #19324d;
  border-radius: 999rpx;
  background: #f38d68;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
}
