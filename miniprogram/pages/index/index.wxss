.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 64rpx 40rpx;
  background: #f7fbff;
}

.hero {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.eyebrow {
  color: #f38d68;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 0;
}

.title {
  color: #19324d;
  font-size: 52rpx;
  font-weight: 800;
  letter-spacing: 0;
}

.subtitle {
  color: #45647f;
  font-size: 30rpx;
  line-height: 1.5;
}

.status-card {
  margin-top: 24rpx;
  padding: 32rpx;
  border: 2rpx solid #183451;
  border-radius: 24rpx;
  background: #ffffff;
}

.status-title {
  display: block;
  color: #19324d;
  font-size: 30rpx;
  font-weight: 700;
}

.status-copy {
  display: block;
  margin-top: 12rpx;
  color: #45647f;
  font-size: 26rpx;
  line-height: 1.5;
}
