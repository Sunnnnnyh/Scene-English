.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 56rpx 32rpx 72rpx;
  background: #f7fbff;
}

.hero {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.eyebrow {
  color: #f38d68;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 0;
}

.title {
  color: #19324d;
  font-size: 56rpx;
  font-weight: 800;
  letter-spacing: 0;
}

.subtitle {
  color: #45647f;
  font-size: 30rpx;
  line-height: 1.5;
}

.section {
  margin-top: 42rpx;
}

.section-title {
  display: block;
  margin-bottom: 20rpx;
  color: #19324d;
  font-size: 32rpx;
  font-weight: 800;
}

.scene-card {
  position: relative;
  overflow: hidden;
  margin-bottom: 24rpx;
  border: 2rpx solid #183451;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(25, 50, 77, 0.08);
}

.scene-card-primary {
  min-height: 476rpx;
}

.scene-card-locked {
  min-height: 196rpx;
  background: #f4f1ff;
}

.scene-cover {
  display: block;
  width: 100%;
  height: 300rpx;
  background: #dfeefa;
}

.scene-content {
  display: flex;
  flex-direction: column;
  gap: 26rpx;
  padding: 28rpx;
}

.scene-name-en {
  display: block;
  color: #19324d;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.2;
}

.scene-name-cn {
  display: block;
  margin-top: 8rpx;
  color: #45647f;
  font-size: 26rpx;
}

.scene-meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.scene-pill {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #e8f5ee;
  color: #1d6b4a;
  font-size: 24rpx;
  font-weight: 700;
}

.scene-pill-muted {
  background: #ffffff;
  color: #64758a;
}

.scene-action {
  min-width: 190rpx;
  box-sizing: border-box;
  padding: 16rpx 22rpx;
  border-radius: 999rpx;
  background: #f38d68;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 800;
  text-align: center;
}

.scene-action-muted {
  background: #d8dded;
  color: #45647f;
}

.coming-soon-mark {
  padding: 22rpx 28rpx 0;
  color: #45647f;
  font-size: 24rpx;
  font-weight: 800;
}
