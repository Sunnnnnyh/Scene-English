<view class="scene-page">
  <block wx:if="{{!activeMode}}">
    <view class="scene-header">
      <view>
        <text class="scene-kicker">Classroom Scene</text>
        <text class="scene-title">{{title}}</text>
      </view>
      <text class="scene-count">{{progressLabel}}</text>
    </view>

    <view class="scene-preview">
      <image class="scene-image" src="{{sceneImage}}" mode="aspectFill" />
    </view>

    <view class="progress-section">
      <view class="progress-track">
        <view class="progress-fill" style="width: {{progressPercent}}%;"></view>
      </view>
    </view>

    <view class="mode-section">
      <text class="section-title">学习模式</text>
      <block wx:for="{{modeEntries}}" wx:key="id">
        <view
          class="mode-entry {{item.isRecommended ? 'mode-entry--recommended' : ''}}"
          data-entry-id="{{item.id}}"
          bindtap="onEntryTap"
        >
          <view class="mode-copy">
            <text class="mode-title">{{item.title}}</text>
            <text class="mode-subtitle">{{item.subtitle}}</text>
          </view>
          <text class="mode-action">{{item.actionLabel}}</text>
        </view>
      </block>
    </view>
  </block>

  <block wx:if="{{activeMode}}">
    <text class="scene-kicker">{{title}}</text>
    <text class="scene-title">{{selectedModeTitle}}</text>
    <text class="mode-page-subtitle">{{selectedModeSubtitle}}</text>

    <block wx:if="{{activeMode === 'memory'}}">
      <view class="scene-preview mode-page-preview memory-scene-preview" bindtap="onMemoryBlankTap">
        <image class="scene-image" src="{{sceneImage}}" mode="aspectFill" />
        <block wx:for="{{memoryHotspots}}" wx:key="wordId">
          <view
            class="memory-hotspot {{showMemoryGuide && item.wordId === memoryGuideWordId ? 'memory-hotspot--guided' : ''}}"
            style="{{item.style}}"
            data-word-id="{{item.wordId}}"
            catchtap="onMemoryHotspotTap"
          ></view>
        </block>
        <view wx:if="{{showMemoryGuide}}" class="memory-guide">
          <text class="memory-guide-title">试试看</text>
          <text class="memory-guide-text">点一点教室里的物品，看看它用英语怎么说</text>
          <button class="memory-guide-close" bindtap="onDismissMemoryGuide">我知道了</button>
        </view>
      </view>

      <view wx:if="{{selectedMemoryWordCard}}" class="memory-word-card">
        <view class="memory-word-card__panel">
          <view class="memory-word-card__header">
            <view>
              <text class="memory-word-card__word">{{selectedMemoryWordCard.en}}</text>
              <text class="memory-word-card__phonetic">{{selectedMemoryWordCard.phonetic}}</text>
            </view>
            <view class="memory-word-card__close" bindtap="onCloseMemoryWordCard">
              <text class="memory-word-card__close-icon">×</text>
            </view>
          </view>

          <text class="memory-word-card__cn">{{selectedMemoryWordCard.cn}}</text>

          <view wx:if="{{showMemoryTranslationGuide}}" class="memory-translation-guide">
            点英文句子可以展开中文，再点一次收起。
          </view>

          <view class="memory-word-card__section">
            <text class="memory-word-card__label">Useful expression</text>
            <text
              class="memory-word-card__line"
              data-translation-type="expression"
              bindtap="onToggleMemoryTranslation"
            >
              {{selectedMemoryWordCard.expressionEn}}
            </text>
            <text
              wx:if="{{selectedMemoryWordCard.showExpressionCn}}"
              class="memory-word-card__translation"
            >
              {{selectedMemoryWordCard.expressionCn}}
            </text>
          </view>
        </view>
      </view>
    </block>

    <block wx:else>
      <view class="scene-preview mode-page-preview">
        <image class="scene-image" src="{{sceneImage}}" mode="aspectFill" />
      </view>

      <view class="mode-page-panel">
        <text class="mode-page-note">当前先保持基础模式视图，后续步骤会继续接入具体练习交互。</text>
      </view>
    </block>

    <button class="back-button" bindtap="onBackToSceneHome">返回 Classroom</button>
  </block>
</view>
