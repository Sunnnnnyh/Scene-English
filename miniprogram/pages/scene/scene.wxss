.scene-page {
  box-sizing: border-box;
  height: 100vh;
  overflow-y: auto;
  padding: 42rpx 32rpx 112rpx;
  padding-bottom: calc(112rpx + env(safe-area-inset-bottom));
  background: #f7fbff;
}

.scene-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 24rpx;
}

.scene-kicker {
  display: block;
  color: #5d7892;
  font-size: 24rpx;
  font-weight: 700;
}

.scene-title {
  display: block;
  margin-top: 8rpx;
  color: #19324d;
  font-size: 42rpx;
  font-weight: 800;
}

.scene-count {
  flex-shrink: 0;
  color: #e8754f;
  font-size: 24rpx;
  font-weight: 800;
}

.scene-preview {
  margin-top: 30rpx;
  overflow: hidden;
  border: 3rpx solid #19324d;
  border-radius: 24rpx;
  background: #eaf5ff;
  box-shadow: 0 16rpx 32rpx rgba(25, 50, 77, 0.08);
}

.scene-image {
  display: block;
  width: 100%;
  height: 380rpx;
}

.progress-section {
  margin-top: 20rpx;
}

.progress-track {
  overflow: hidden;
  height: 16rpx;
  border: 2rpx solid #19324d;
  border-radius: 999rpx;
  background: #ffffff;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: #ff946f;
}

.mode-section {
  margin-top: 40rpx;
}

.section-title {
  display: block;
  margin-bottom: 16rpx;
  color: #19324d;
  font-size: 30rpx;
  font-weight: 800;
}

.mode-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  box-sizing: border-box;
  min-height: 142rpx;
  margin-top: 18rpx;
  padding: 22rpx 24rpx;
  border: 3rpx solid #19324d;
  border-radius: 22rpx;
  background: #ffffff;
}

.mode-entry--recommended {
  background: #fff4df;
}

.mode-copy {
  min-width: 0;
}

.mode-title {
  display: block;
  color: #19324d;
  font-size: 30rpx;
  font-weight: 800;
}

.mode-subtitle {
  display: block;
  margin-top: 6rpx;
  color: #45647f;
  font-size: 23rpx;
  line-height: 1.4;
}

.mode-action {
  flex-shrink: 0;
  min-width: 176rpx;
  box-sizing: border-box;
  padding: 11rpx 16rpx;
  border: 2rpx solid #19324d;
  border-radius: 999rpx;
  background: #ffffff;
  color: #19324d;
  font-size: 22rpx;
  font-weight: 800;
  text-align: center;
}

.mode-page-subtitle {
  display: block;
  margin-top: 22rpx;
  color: #45647f;
  font-size: 28rpx;
  line-height: 1.5;
}

.mode-page-preview {
  margin-top: 34rpx;
}

.memory-scene-preview {
  position: relative;
}

.memory-hotspot {
  position: absolute;
  z-index: 2;
  box-sizing: border-box;
  background: rgba(255, 148, 111, 0);
}

.memory-hotspot:active {
  border: 2rpx solid rgba(25, 50, 77, 0.35);
  background: rgba(255, 148, 111, 0.22);
}

.mode-page-panel {
  margin-top: 28rpx;
  padding: 24rpx;
  border: 3rpx solid #19324d;
  border-radius: 22rpx;
  background: #ffffff;
}

.mode-page-note {
  display: block;
  color: #45647f;
  font-size: 26rpx;
  line-height: 1.5;
}

.back-button {
  margin: 40rpx 0 0;
  min-height: 88rpx;
  border: 2rpx solid #19324d;
  border-radius: 999rpx;
  background: #f38d68;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
}
